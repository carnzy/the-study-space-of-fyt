---
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>冯羽彤的学习基地</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="min-h-screen pt-14 md:pt-16 pb-16 md:pb-0">
  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 h-14 md:h-16 bg-white border-b border-slate-200 z-50 flex items-center px-3 md:px-6 gap-3">
    <button onclick="toggleLeft()" class="md:hidden p-2 -ml-1 rounded-lg hover:bg-slate-100" aria-label="菜单">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <h1 class="text-base md:text-lg font-bold flex items-center gap-2 flex-1 truncate">
      <span class="text-xl">📚</span>
      <span class="hidden sm:inline">冯羽彤的学习基地</span>
      <span class="sm:hidden">学习基地</span>
    </h1>
    <a href="/posts/new" class="hidden md:inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-500 text-white rounded-lg text-sm font-medium hover:bg-indigo-600 transition-colors">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      新增错题
    </a>
    <a href="/settings" class="p-2 rounded-lg hover:bg-slate-100" title="设置">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
    </a>
  </header>

  <div class="flex max-w-7xl mx-auto min-h-[calc(100vh-3.5rem)] md:min-h-[calc(100vh-4rem)]">
    <!-- 左侧边栏：科目标签 -->
    <aside id="leftSidebar" class="hidden md:block w-60 lg:w-64 flex-shrink-0 bg-white border-r border-slate-200 overflow-y-auto sticky top-14 md:top-16 h-[calc(100vh-3.5rem)] md:h-[calc(100vh-4rem)]">
      <div id="sidebar-container" class="p-4">
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-3">�� 科目分类</h2>
        <div id="subjectNav" class="space-y-1 text-sm text-slate-400">加载中...</div>
      </div>
    </aside>

    <!-- 移动端左侧抽屉 -->
    <div id="leftDrawer" class="fixed inset-y-0 left-0 z-40 w-72 max-w-[85vw] bg-white shadow-2xl transform -translate-x-full transition-transform duration-300 md:hidden">
      <div class="pt-14 h-full overflow-y-auto p-4">
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-3">📂 科目分类</h2>
        <div id="subjectNavMobile" class="space-y-1 text-sm text-slate-400">加载中...</div>
      </div>
    </div>

    <!-- 中间内容区 -->
    <main class="flex-1 min-w-0 px-3 py-4 md:px-6 md:py-6">
      <slot />
    </main>

    <!-- 右侧边栏：日历 -->
    <aside id="rightSidebar" class="hidden md:block w-60 lg:w-64 flex-shrink-0 bg-white border-l border-slate-200 overflow-y-auto sticky top-14 md:top-16 h-[calc(100vh-3.5rem)] md:h-[calc(100vh-4rem)]">
      <div id="calendar-container" class="p-4"></div>
    </aside>

    <!-- 移动端右侧抽屉 -->
    <div id="rightDrawer" class="fixed inset-y-0 right-0 z-40 w-72 max-w-[85vw] bg-white shadow-2xl transform translate-x-full transition-transform duration-300 md:hidden">
      <div class="pt-14 p-4 h-full overflow-y-auto">
        <div id="calendarMobile"></div>
      </div>
    </div>
  </div>

  <!-- 遮罩 -->
  <div id="overlay" class="fixed inset-0 bg-black/30 z-30 hidden md:hidden" onclick="closeDrawers()"></div>

  <!-- 移动端底部导航 -->
  <nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-slate-200 z-50 flex md:hidden">
    <button onclick="toggleLeft()" class="flex-1 flex flex-col items-center justify-center py-2 text-slate-400">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
      <span class="text-[10px] mt-0.5">科目</span>
    </button>
    <a href="/" class="flex-1 flex flex-col items-center justify-center py-2 text-indigo-500">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span class="text-[10px] mt-0.5">首页</span>
    </a>
    <button onclick="toggleRight()" class="flex-1 flex flex-col items-center justify-center py-2 text-slate-400">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <span class="text-[10px] mt-0.5">日历</span>
    </button>
    <a href="/posts/new" class="flex-1 flex flex-col items-center justify-center py-2 text-slate-400">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      <span class="text-[10px] mt-0.5">新增</span>
    </a>
  </nav>

  <script>
    window.closeDrawers = function() {
      document.getElementById('leftDrawer')?.classList.add('-translate-x-full');
      document.getElementById('leftDrawer')?.classList.remove('translate-x-0');
      document.getElementById('rightDrawer')?.classList.add('translate-x-full');
      document.getElementById('rightDrawer')?.classList.remove('translate-x-0');
      document.getElementById('overlay')?.classList.add('hidden');
    };
    window.toggleLeft = function() {
      const d = document.getElementById('leftDrawer');
      const o = document.getElementById('overlay');
      if (d?.classList.contains('-translate-x-full')) {
        d.classList.remove('-translate-x-full'); d.classList.add('translate-x-0');
        o?.classList.remove('hidden');
      } else { closeDrawers(); }
    };
    window.toggleRight = function() {
      const d = document.getElementById('rightDrawer');
      const o = document.getElementById('overlay');
      if (d?.classList.contains('translate-x-full')) {
        d.classList.remove('translate-x-full'); d.classList.add('translate-x-0');
        o?.classList.remove('hidden');
      } else { closeDrawers(); }
    };
  </script>

  <!-- 侧边栏 + 日历客户端渲染 -->
  <script type="module">
    import { createRoot } from 'react-dom/client';
    import React from 'react';
    import Sidebar from '../components/Sidebar.tsx';
    import Calendar from '../components/Calendar.tsx';

    // 渲染桌面端侧边栏
    const desktopNav = document.getElementById('subjectNav');
    if (desktopNav) createRoot(desktopNav).render(React.createElement(Sidebar));
    const mobileNav = document.getElementById('subjectNavMobile');
    if (mobileNav) createRoot(mobileNav).render(React.createElement(Sidebar));

    // 渲染日历
    const calContainer = document.getElementById('calendar-container');
    if (calContainer) createRoot(calContainer).render(React.createElement(Calendar));
    const calMobile = document.getElementById('calendarMobile');
    if (calMobile) createRoot(calMobile).render(React.createElement(Calendar));
  </script>
</body>
</html>
